# --- Python Standard ---
__pycache__/
*.py[oc]
**/.pytest_cache/
build/
dist/
wheels/
*.egg-info

# --- Virtual Environments (UV) ---
.venv/
# Nota: uv.lock SÍ se debe subir al repo (como package-lock.json), 
# así que no lo agregues aquí.

# A veces los agentes generan logs locales muy largos
*.log

# --- Outputs & Data ---
*.db
leads.db
bastion_bot.db
data/
checkpointer.sqlite
*.xlsx
leads/


# --- Environment Variables (Seguridad CRÍTICA) ---
*.env
.env.*
# Por si acaso tienes un archivo de claves específico
keys.json
secrets.json

# --- macOS (Molestos archivos del sistema) ---
.DS_Store

# --- IDEs (Opcional, pero recomendado para no ensuciar el repo) ---
.vscode/
.idea/

# --- Notebooks (Si usas Jupyter para probar los agentes) ---
.ipynb_checkpoints/

.langgraph_api/

# --- Antigravity Global Skills ---
.agents/

# --- Frontend (Next.js) ---
**/node_modules/
frontend/.pnp
frontend/.pnp.*
frontend/.yarn/*
!frontend/.yarn/patches
!frontend/.yarn/plugins
!frontend/.yarn/releases
!frontend/.yarn/versions
frontend/coverage/
**/ .next/
frontend/out/
frontend/build/
frontend/*.pem
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/.pnpm-debug.log*
